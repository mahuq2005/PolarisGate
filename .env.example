# ═══════════════════════════════════════════════════════════════════════════
# PolarisGate Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# Generate secrets with: openssl rand -hex 64
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────────────────
# PostgreSQL connection string for the primary database
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Optional read replica for query offloading
READ_DATABASE_URL=${DATABASE_URL}

# PostgreSQL credentials (used by docker-compose to create the database)
POSTGRES_USER=polarisgate
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=polarisgate

# ─── Redis ────────────────────────────────────────────────────────────────
# Redis password for authentication
REDIS_PASSWORD=CHANGE_ME_TO_A_STRONG_REDIS_PASSWORD
REDIS_HOST=redis

# ─── JWT Authentication ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
# Minimum 32 bytes (256 bits) for HS256
JWT_SECRET=CHANGE_ME_TO_A_64_CHAR_HEX_STRING_USE_openssl_rand_hex_64

# ─── Ollama LLM ───────────────────────────────────────────────────────────
# URL for the Ollama API server
OLLAMA_URL=http://ollama:11434

# Model name for toxicity classification
# Options: llama3.2:1b (fast), llama3.2:3b (accurate), tinyllama (fallback)
TOXIC_MODEL_NAME=llama3.2:1b

# ─── Frontend ─────────────────────────────────────────────────────────────
# Public API URL (used by the browser)
NEXT_PUBLIC_API_URL=https://polarisgate.local

# ─── Observability ────────────────────────────────────────────────────────
# Enable Prometheus metrics
ENABLE_METRICS=true

# OpenTelemetry OTLP endpoint (e.g., Jaeger, Grafana Tempo, SigNoz)
# Leave empty to disable OTLP export
OTEL_EXPORTER_OTLP_ENDPOINT=

# OpenTelemetry service name
OTEL_SERVICE_NAME=polarisgate

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable JSON structured logging
LOG_JSON_FORMAT=true

# ─── Service URLs (Internal) ──────────────────────────────────────────────
# These are used for inter-service communication within Docker network
GUARDRAILS_URL=http://guardrails:8005
AIDA_URL=http://aida-bridge:8001
COLLECTOR_URL=http://collector:8006
BIAS_URL=http://bias-monitor:8007

# ─── Rate Limiting ────────────────────────────────────────────────────────
# Default rate limits (requests per minute)
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_AUTH=30
RATE_LIMIT_GUARDRAILS=60

# ─── Security ─────────────────────────────────────────────────────────────
# Enable hybrid PII detection (Presidio + Canadian recognizers)
# Set to "false" to use legacy regex-only engine
PII_HYBRID_ENABLED=true

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://polarisgate.local,http://localhost:3000

# Token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── mTLS / Certificate Authority ─────────────────────────────────────────
# Enable mTLS for service-to-service communication
# Set to "true" for production deployments
MTLS_ENABLED=false

# CA provider: "internal" (self-signed) or "custom" (BYOC)
CA_PROVIDER=internal

# CA key size (bits): 4096 for RSA, 256/384 for EC
CA_KEY_SIZE=4096

# CA certificate validity (days)
CA_CERT_VALIDITY_DAYS=365

# Service certificate validity (days) - shorter for better security
CA_SERVICE_CERT_VALIDITY_DAYS=30

# Sidecar proxy auth token (shared secret with kill-switch)
# Generate with: openssl rand -hex 32
SIDECAR_AUTH_TOKEN=CHANGE_ME_TO_A_64_CHAR_HEX_STRING

# Kill method: "sidecar" (recommended) or "docker_socket"
KILL_METHOD=sidecar

# ─── Demo Mode ────────────────────────────────────────────────────────────
# Set to "true" to enable demo data for evaluation/trials
# Set to "false" for production deployments
DEMO_MODE=false

# ─── OPA Policy Engine ────────────────────────────────────────────────────
# OPA service URL
OPA_URL=http://opa:8181

# OPA enforcement mode: "true" to enforce, "false" to log only
OPA_ENFORCED=true

# OPA fail mode: "fail_open", "fail_closed", or "risk_based"
# risk_based: blocks only high/critical risk decisions when OPA is down
OPA_FAIL_MODE=risk_based

# OPA circuit breaker threshold (failures before opening circuit)
OPA_CIRCUIT_THRESHOLD=5

# ─── Pre-flight Security Checks ──────────────────────────────────────────
# Set to "true" to allow startup even if critical checks fail
# NOT RECOMMENDED for production
SECURITY_CHECKS_FAIL_OPEN=false

# ─── Encryption ──────────────────────────────────────────────────────────
# AES-256 encryption key for data-at-rest (base64 encoded, 32 bytes)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# ─── RBAC (Role-Based Access Control) ─────────────────────────────────────
# Default role for new users (admin, operator, auditor, viewer)
DEFAULT_USER_ROLE=viewer

# ─── Session Management ───────────────────────────────────────────────────
# Maximum concurrent sessions per user
MAX_CONCURRENT_SESSIONS=5

# Session TTL in seconds (default: 24 hours)
SESSION_TTL_SECONDS=86400

# ─── API Key Management ───────────────────────────────────────────────────
# Default expiration for API keys in days
API_KEY_DEFAULT_EXPIRY_DAYS=365

# ─── Input Sanitization ──────────────────────────────────────────────────
# Enable global input sanitization middleware
INPUT_SANITIZATION_ENABLED=true

# Maximum request body size in bytes (default: 1MB)
MAX_REQUEST_BODY_SIZE=1000000

# ─── WAF (Web Application Firewall) ──────────────────────────────────────
# Enable WAF rules in nginx
WAF_ENABLED=true

# Block requests with no User-Agent header
WAF_BLOCK_NO_USER_AGENT=true

# Block known malicious scanners
WAF_BLOCK_MALICIOUS_BOTS=true

# ─── Data Retention ──────────────────────────────────────────────────────
# Auto-cleanup traces older than this many days
DATA_RETENTION_DAYS=90

# Audit log retention in days (default: 2 years for compliance)
AUDIT_LOG_RETENTION_DAYS=730

# ─── Compliance ──────────────────────────────────────────────────────────
# Enable AIDA transparency reporting
AIDA_TRANSPARENCY_ENABLED=true

# Enable EU AI Act compliance checks
EU_AI_ACT_ENABLED=true

# Enable SOC 2 audit logging enhancements
SOC2_AUDIT_ENABLED=true

# ─── Rate Limiting (Per-User) ────────────────────────────────────────────
# Per-user rate limit (requests per minute) based on JWT/API key
RATE_LIMIT_PER_USER=30

# ─── Feature Flags ───────────────────────────────────────────────────────
# Enable user management endpoints
USER_MANAGEMENT_ENABLED=true

# Enable API key management endpoints
API_KEY_MANAGEMENT_ENABLED=true

# Enable session management endpoints
SESSION_MANAGEMENT_ENABLED=true

# ─── Vault (Secrets Management) ──────────────────────────────────────────
# Enable HashiCorp Vault integration for secrets management
VAULT_ENABLED=false

# Vault server address
VAULT_ADDR=http://vault:8200

# Vault authentication token (use Vault Agent or Kubernetes auth in prod)
VAULT_TOKEN=

# Vault KV engine path for secrets
VAULT_KV_PATH=secret/polarisgate

# ─── FIPS 140-2/140-3 Compliance ────────────────────────────────────────
# Enable FIPS-compliant cryptographic operations
# Requires FIPS-validated OpenSSL module (e.g., OpenSSL 3.x FIPS provider)
FIPS_MODE=false

# Path to FIPS provider module (OpenSSL 3.x)
FIPS_PROVIDER_PATH=/usr/lib/ssl/fipsmodule.cnf

# ─── Compliance Mode ────────────────────────────────────────────────────
# Compliance mode: "full" (all frameworks), "minimal" (AIDA only), "custom"
COMPLIANCE_MODE=full

# Enable GDPR compliance features (data portability, right to erasure)
GDPR_ENABLED=true

# Enable HIPAA compliance features (BAAs, PHI handling)
HIPAA_ENABLED=false

# Enable PCI DSS compliance features (card data detection, SAQ)
PCI_ENABLED=false

# Enable SOC 2 compliance features (enhanced audit, availability controls)
SOC2_ENABLED=true

# Enable ISO 42001 compliance features (AI management system)
ISO42001_ENABLED=true

# Enable NIST AI RMF compliance features (AI risk management)
NIST_AI_RMF_ENABLED=true

# ─── Data Loss Prevention (DLP) ─────────────────────────────────────────
# Enable DLP engine for content inspection
DLP_ENABLED=true

# DLP action on violation: "block", "mask", "alert", "log"
DLP_DEFAULT_ACTION=alert

# DLP scan depth: "fast" (regex only), "deep" (regex + ML), "full" (all)
DLP_SCAN_DEPTH=deep

# ─── Data Classification ────────────────────────────────────────────────
# Enable automatic data classification
DATA_CLASSIFICATION_ENABLED=true

# Default classification for unclassified data
DEFAULT_DATA_CLASSIFICATION=internal

# ─── Consent Management ─────────────────────────────────────────────────
# Enable user consent tracking
CONSENT_MANAGEMENT_ENABLED=true

# Consent storage backend: "database", "redis", "both"
CONSENT_STORAGE_BACKEND=database

# ─── Breach Notification ────────────────────────────────────────────────
# Enable automated breach notification
BREACH_NOTIFICATION_ENABLED=true

# Breach notification method: "email", "webhook", "both"
BREACH_NOTIFICATION_METHOD=email

# Email address for breach notifications
BREACH_NOTIFICATION_EMAIL=security@northguard.ai

# Breach notification webhook URL
BREACH_NOTIFICATION_WEBHOOK=

# Notification deadlines (hours) per severity
BREACH_NOTIFICATION_HIGH_HOURS=24
BREACH_NOTIFICATION_MEDIUM_HOURS=72
BREACH_NOTIFICATION_LOW_HOURS=168

# ─── Audit Chain (Tamper-Proof) ─────────────────────────────────────────
# Enable blockchain-style audit chain
AUDIT_CHAIN_ENABLED=true

# Audit chain hashing algorithm: "sha256", "sha512"
AUDIT_CHAIN_HASH_ALGORITHM=sha256

# ─── PCI DSS ────────────────────────────────────────────────────────────
# PCI DSS SAQ type (A, A_EP, B, B_IP, C, C_VT, D, P2PE)
PCI_SAQ_TYPE=D

# PCI compliance storage path
PCI_STORAGE_PATH=/app/pci

# ─── Encryption at Rest ─────────────────────────────────────────────────
# Encryption algorithm: "AES-256-GCM", "AES-256-CBC", "ChaCha20-Poly1305"
ENCRYPTION_ALGORITHM=AES-256-GCM

# Enable field-level encryption for PII data
FIELD_LEVEL_ENCRYPTION=true

# ─── Audit Enhancements ────────────────────────────────────────────────
# Enable before/after state tracking in audit logs
AUDIT_STATE_TRACKING=true

# Enable correlation ID tracking across services
AUDIT_CORRELATION_TRACKING=true

# ─── Security Monitoring ────────────────────────────────────────────────
# Enable real-time security event monitoring
SECURITY_MONITORING_ENABLED=true

# Security event retention (days)
SECURITY_EVENT_RETENTION_DAYS=365

# Enable automated threat detection
THREAT_DETECTION_ENABLED=true
